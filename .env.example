# Copy this file to .env and fill in your values.
# SQLite (default, works immediately):
DATABASE_URL=sqlite:///./database/stud_dash.db

# PostgreSQL (when available):
# DATABASE_URL=postgresql://user:password@localhost:5432/stud_dash

SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_TITLE=Stud-Dash EDW
ENVIRONMENT=development
